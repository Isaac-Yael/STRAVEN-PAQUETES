<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ page_title }}</title>
<meta name="description" content="{% block meta_desc %}Paquetes de mercancía 100% original importada de Estados Unidos, al mayoreo. Ideal para revendedores, mayoristas y dueños de negocio.{% endblock %}">
<link rel="icon" type="image/webp" href="{{ asset_prefix }}img/logo_ch.webp">
<link rel="stylesheet" href="{{ asset_prefix }}css/styles.css">
</head>
<body class="{% block body_class %}{% endblock %}">
<div class="bg-glow"></div>

{% macro trust_msgs() -%}
<span class="promo-marquee-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="14" height="11"/><path d="M15 9h4l3 3v5h-7z"/><circle cx="6" cy="19" r="1.6"/><circle cx="17" cy="19" r="1.6"/></svg>Envío Gratis</span>
<span class="promo-marquee-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>100% original</span>
<span class="promo-marquee-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/></svg>Paga a 3 meses sin intereses</span>
{%- endmacro %}
<div class="site-top-fixed">
  <div class="promo-marquee">
    <div class="promo-marquee-track">
      <div class="promo-marquee-set">{{ trust_msgs() }}{{ trust_msgs() }}{{ trust_msgs() }}</div>
      <div class="promo-marquee-set" aria-hidden="true">{{ trust_msgs() }}{{ trust_msgs() }}{{ trust_msgs() }}</div>
    </div>
  </div>

  {% include "header.html.j2" %}
</div>

<main>
{% block content %}{% endblock %}
</main>

{% include "footer.html.j2" %}

<a href="#" id="whatsapp-float-btn" class="whatsapp-float" target="_blank" rel="noopener" aria-label="Escríbenos por WhatsApp">
  <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor"><path d="M16.04 2.67C8.84 2.67 3 8.5 3 15.7c0 2.84.93 5.46 2.5 7.6L4 29.33l6.2-1.63a12.9 12.9 0 0 0 5.84 1.4h.01c7.2 0 13.04-5.83 13.04-13.03 0-3.48-1.36-6.75-3.82-9.2a12.93 12.93 0 0 0-9.23-3.8Zm0 23.4h-.01a10.8 10.8 0 0 1-5.5-1.5l-.4-.24-4.1 1.08 1.1-4-.26-.42a10.78 10.78 0 0 1-1.65-5.74c0-5.98 4.87-10.84 10.85-10.84a10.8 10.8 0 0 1 7.68 3.18 10.78 10.78 0 0 1 3.18 7.67c0 5.98-4.87 10.81-10.85 10.81Zm5.95-8.1c-.33-.16-1.93-.95-2.23-1.06-.3-.11-.51-.16-.73.16-.21.32-.84 1.06-1.03 1.27-.19.22-.38.24-.7.08-.32-.16-1.34-.49-2.55-1.57-.94-.84-1.58-1.87-1.76-2.19-.19-.32-.02-.49.15-.65.16-.16.36-.41.54-.62.18-.21.24-.36.36-.6.12-.24.06-.44-.03-.6-.1-.16-.66-1.6-.91-2.18-.24-.58-.49-.5-.68-.51h-.58c-.19 0-.5.07-.76.36-.27.29-1.03 1-1.03 2.45s1.06 2.84 1.21 3.04c.16.2 2.13 3.25 5.16 4.43 3.03 1.18 3.03.79 3.58.74.54-.05 1.93-.79 2.2-1.55.28-.76.28-1.41.2-1.55-.08-.13-.3-.21-.62-.37Z"/></svg>
</a>

<script src="{{ asset_prefix }}js/config.js"></script>
<script src="{{ asset_prefix }}js/cart.js"></script>
{% block extra_scripts %}{% endblock %}
</body>
</html>
