{% extends "base.html.j2" %}
{% block content %}
<div class="container">

  <div class="filters-wrap">
    <div class="filters">
      <button class="pill active" data-cat="todos">Todos</button>
      {% for cat in categories %}
      <button class="pill" data-cat="{{ cat.slug }}">{{ cat.nombre }}</button>
      {% endfor %}
    </div>
  </div>

  {% for cat in categories %}
  <section class="cat-section" data-cat="{{ cat.slug }}">
    <div class="cat-heading">
      <h2>{{ cat.nombre }}</h2>
      <span class="cat-count">{{ cat.productos|length }} {{ "paquete" if cat.productos|length == 1 else "paquetes" }}</span>
    </div>
    <div class="grid">
      {% for p in cat.productos %}
      {% include "card.html.j2" %}
      {% endfor %}
    </div>
  </section>
  {% endfor %}

  <div class="no-results" id="no-results" style="display:none;">No hay paquetes en esta categoría por ahora.</div>
</div>
{% endblock %}
{% block extra_scripts %}<script src="js/main.js"></script>{% endblock %}
