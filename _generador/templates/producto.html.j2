{% extends "base.html.j2" %}
{% block meta_desc %}{{ p.meta_desc }}{% endblock %}
{% block body_class %}has-buybar{% endblock %}
{% block content %}

{% macro spec_icon(key) -%}
{% if key == "piezas" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8l-9-5-9 5 9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/></svg>
{% elif key == "precio_unit" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41L11 3.83A2 2 0 0 0 9.59 3.24L4 3a1 1 0 0 0-1 1l.24 5.59a2 2 0 0 0 .59 1.41l9.58 9.58a2 2 0 0 0 2.83 0l4.35-4.35a2 2 0 0 0 0-2.82z"/><circle cx="7.5" cy="7.5" r="1.2"/></svg>
{% elif key == "precio_total" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 9v6M18 9v6"/></svg>
{% elif key == "marcas" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l2.9 6 6.6.6-5 4.4 1.5 6.5L12 16l-5.9 3.5L7.6 13l-5-4.4 6.6-.6z"/></svg>
{% elif key == "presentaciones" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l9 5-9 5-9-5z"/><path d="M3 12l9 5 9-5"/><path d="M3 17l9 5 9-5"/></svg>
{% elif key == "tallas" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="10" rx="1"/><path d="M6 7v4M10 7v3M14 7v4M18 7v3"/></svg>
{% elif key == "peso" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v3"/><path d="M5 7h14l1.5 12a2 2 0 0 1-2 2H5.5a2 2 0 0 1-2-2L5 7z"/><path d="M8 7a4 4 0 0 1 8 0"/></svg>
{% elif key == "medidas" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h4M3 15h4M21 9h-4M21 15h-4M9 3v4M15 3v4M9 21v-4M15 21v-4"/></svg>
{% elif key == "extras" %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="8" width="18" height="13" rx="1"/><path d="M3 8l2-4h14l2 4"/><path d="M12 8v13"/></svg>
{% endif %}
{%- endmacro %}

<!-- ===== HERO: foto principal + caja de compra ===== -->
<div class="container product-top">
  <div class="product-grid">

    <div class="gallery">
      <button type="button" class="gallery-main js-lightbox-img" data-group="principal">
        <img src="{{ p.principal_detail }}" alt="{{ p.nombre }}">
      </button>
    </div>

    <div class="buy-box">
      <div class="buy-eyebrow">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
        Envío Gratis y 3 MSI con Paypal
      </div>
      <h1 class="buy-title">{{ p.nombre }}</h1>

      {% if p.logos %}
      <div class="brand-logos">
        {% for logo in p.logos %}<img src="{{ logo }}" class="brand-logo-chip" alt="Marca incluida en el paquete">{% endfor %}
      </div>
      {% endif %}

      <div class="buy-price-row">
        <div class="buy-price-col">
          <div class="buy-price-block">
            <span class="buy-price js-count-price" data-count="load" data-final="{{ p.precio_total_num }}">{{ p.precio_total }}</span>
          </div>
          <div class="buy-unit">{{ p.precio_unitario }} c/u · {{ p.pzas }} piezas</div>
          <div class="buy-disclaimer-mini">Este paquete se surte sin selección personalizada de modelos, tallas o presentaciones.</div>
        </div>

        <div class="buy-countdown" id="buy-countdown">
          <div class="buy-countdown-label">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3.5 2"/></svg>
            Oferta por tiempo limitado · termina en
          </div>
          <div class="buy-countdown-timer" aria-live="polite">
            <div class="buy-countdown-unit"><span class="js-cd-h">--</span><small>hrs</small></div>
            <span class="buy-countdown-sep">:</span>
            <div class="buy-countdown-unit"><span class="js-cd-m">--</span><small>min</small></div>
            <span class="buy-countdown-sep">:</span>
            <div class="buy-countdown-unit"><span class="js-cd-s">--</span><small>seg</small></div>
          </div>
        </div>
      </div>

      <div class="buy-actions">
        <button type="button" class="btn btn-primary btn-block js-buy-now">Comprar Ahora 🔥</button>
        <a href="#" class="btn btn-whatsapp btn-block js-whatsapp-quote" target="_blank" rel="noopener">
          <svg viewBox="0 0 32 32" width="18" height="18" fill="currentColor"><path d="M16.04 2.67C8.84 2.67 3 8.5 3 15.7c0 2.84.93 5.46 2.5 7.6L4 29.33l6.2-1.63a12.9 12.9 0 0 0 5.84 1.4h.01c7.2 0 13.04-5.83 13.04-13.03 0-3.48-1.36-6.75-3.82-9.2a12.93 12.93 0 0 0-9.23-3.8Zm0 23.4h-.01a10.8 10.8 0 0 1-5.5-1.5l-.4-.24-4.1 1.08 1.1-4-.26-.42a10.78 10.78 0 0 1-1.65-5.74c0-5.98 4.87-10.84 10.85-10.84a10.8 10.8 0 0 1 7.68 3.18 10.78 10.78 0 0 1 3.18 7.67c0 5.98-4.87 10.81-10.85 10.81Zm5.95-8.1c-.33-.16-1.93-.95-2.23-1.06-.3-.11-.51-.16-.73.16-.21.32-.84 1.06-1.03 1.27-.19.22-.38.24-.7.08-.32-.16-1.34-.49-2.55-1.57-.94-.84-1.58-1.87-1.76-2.19-.19-.32-.02-.49.15-.65.16-.16.36-.41.54-.62.18-.21.24-.36.36-.6.12-.24.06-.44-.03-.6-.1-.16-.66-1.6-.91-2.18-.24-.58-.49-.5-.68-.51h-.58c-.19 0-.5.07-.76.36-.27.29-1.03 1-1.03 2.45s1.06 2.84 1.21 3.04c.16.2 2.13 3.25 5.16 4.43 3.03 1.18 3.03.79 3.58.74.54-.05 1.93-.79 2.2-1.55.28-.76.28-1.41.2-1.55-.08-.13-.3-.21-.62-.37Z"/></svg>
          Solicitar cotización por WhatsApp
        </a>
      </div>

      <div class="buy-payment-mini">
        <div class="buy-payment-mini-item reveal" style="transition-delay:0ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 9v6M18 9v6"/></svg>
          <span>Efectivo</span>
        </div>
        <div class="buy-payment-mini-item reveal" style="transition-delay:60ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h13M13 3l4 4-4 4"/><path d="M20 17H7M11 21l-4-4 4-4"/></svg>
          <span>Transferencia</span>
        </div>
        <div class="buy-payment-mini-item reveal" style="transition-delay:120ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/><path d="M14 15h4"/></svg>
          <span>Tarjeta</span>
        </div>
        <div class="buy-payment-mini-item reveal" style="transition-delay:180ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l1.5-5h15L21 9"/><path d="M4 9v10a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V9"/><path d="M9 20v-6h6v6"/><path d="M3 9h18"/></svg>
          <span>Oxxo Pay</span>
        </div>
        <div class="buy-payment-mini-item reveal" style="transition-delay:240ms">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="13" rx="2"/><path d="M2 10h20"/><circle cx="17" cy="14.5" r="1.4"/></svg>
          <span>PayPal</span>
        </div>
      </div>

      {% if p.gallery_sections %}
      <div class="scroll-hint">
        <span>Desliza para ver todos los detalles del paquete</span>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 9l6 6 6-6"/></svg>
      </div>
      {% endif %}
    </div>
  </div>
</div>

{% if p.ganancia_paquete %}
<!-- ===== CRECE TUS GANANCIAS: tabla comparativa de rentabilidad ===== -->
<div class="story-section profit-section">
  <div class="container">
    <div class="story-head reveal">
      <div class="story-eyebrow">RENTABILIDAD COMPROBADA</div>
      <h2 class="story-title">Crece tus Ganancias</h2>
      <p class="story-sub">Compra al mayoreo, revende a precio de mercado y quédate con la diferencia: así de simple es el negocio.</p>
    </div>

    <div class="profit-grid">
      <div class="profit-card reveal" style="transition-delay:0ms">
        <div class="profit-card-icon profit-icon-buy">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41L11 3.83A2 2 0 0 0 9.59 3.24L4 3a1 1 0 0 0-1 1l.24 5.59a2 2 0 0 0 .59 1.41l9.58 9.58a2 2 0 0 0 2.83 0l4.35-4.35a2 2 0 0 0 0-2.82z"/><circle cx="7.5" cy="7.5" r="1.2"/></svg>
        </div>
        <div class="profit-card-label">Lo compras en</div>
        <div class="profit-card-value">{{ p.compra_unit }}</div>
        <div class="profit-card-sub">precio mayorista por pieza</div>
      </div>

      <div class="profit-arrow reveal" style="transition-delay:60ms">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </div>

      <div class="profit-card reveal" style="transition-delay:120ms">
        <div class="profit-card-icon profit-icon-sell">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 7h12l1 13H5z"/><path d="M9 7a3 3 0 0 1 6 0"/></svg>
        </div>
        <div class="profit-card-label">Lo vendes en</div>
        <div class="profit-card-value">{{ p.venta_unit }}</div>
        <div class="profit-card-sub">precio sugerido de venta</div>
      </div>

      <div class="profit-arrow reveal" style="transition-delay:180ms">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </div>

      <div class="profit-card profit-card-win reveal" style="transition-delay:240ms">
        <div class="profit-card-icon profit-icon-win">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 17l6-6 4 4 7-8"/><path d="M14 6h7v7"/></svg>
        </div>
        <div class="profit-card-label">Le ganas</div>
        <div class="profit-card-value">{{ p.ganancia_unit }}</div>
        <div class="profit-card-sub">de ganancia por pieza</div>
      </div>
    </div>

    <div class="profit-total reveal">
      <div class="profit-total-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M16 12a2 2 0 1 0 0 .01"/><path d="M3 9h18"/></svg>
      </div>
      <div class="profit-total-text">
        <span class="profit-total-label">Si revendes las {{ p.pzas }} piezas del paquete, tu ganancia total es de</span>
        <span class="profit-total-value js-count-price" data-count="scroll" data-final="{{ p.ganancia_paquete_num }}">{{ p.ganancia_paquete }}</span>
      </div>
    </div>
  </div>
</div>
{% endif %}

<!-- ===== SECCIONES NARRATIVAS: fotos individuales, detalles y video — aparecen al hacer scroll, justo después de "Crece tus Ganancias" ===== -->
{% for sec in p.gallery_sections %}
<div class="story-section gallery-accordion-section">
  <div class="container">
    <div class="story-head reveal">
      <div class="story-head-text">
        <div class="story-eyebrow">{{ sec.eyebrow }}</div>
        <h2 class="story-title">{{ sec.title }}</h2>
        {% if sec.key == "individuales" and (p.presentaciones_txt or p.tallas_txt) %}
        {% if p.presentaciones_txt %}<p class="story-sub">Presentaciones: {{ p.presentaciones_txt }}</p>{% endif %}
        {% if p.tallas_txt %}<p class="story-sub">Tallas / variantes: {{ p.tallas_txt }}</p>{% endif %}
        {% else %}
        <p class="story-sub">{{ sec.subtitle }}</p>
        {% endif %}
        {% if sec.key == "individuales" %}
        <p class="gallery-disclaimer">{{ sec.subtitle }}</p>
        {% endif %}
      </div>
    </div>

    <div class="gallery-accordion-inner">

        {% if sec.key == "video" %}
        <div class="video-frame reveal">
          <video controls playsinline {% if sec.fotos[0].poster %}poster="{{ sec.fotos[0].poster }}"{% endif %}>
            <source src="{{ sec.fotos[0].src }}">
          </video>
        </div>
        {% else %}
        <div class="photo-carousel-wrap">
          <button type="button" class="carousel-arrow js-carousel-prev" aria-label="Ver fotos anteriores" disabled>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="photo-grid photo-grid--scroll js-carousel-track">
            {% for it in sec.fotos %}
            <button type="button" class="photo-tile js-lightbox-img reveal" data-group="{{ sec.key }}" style="transition-delay:{{ (loop.index0 % 6) * 70 }}ms">
              <img src="{{ it.src }}" alt="{{ p.nombre }} — {{ sec.title }}" loading="lazy">
            </button>
            {% endfor %}
          </div>
          <button type="button" class="carousel-arrow js-carousel-next" aria-label="Ver más fotos">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
        <div class="carousel-dots js-carousel-dots" role="tablist" aria-label="Navegación del carrusel de fotos"></div>
        {% endif %}

    </div>
  </div>
</div>

{% if loop.last %}
<div class="story-section cta-banner-section">
  <div class="container">
    <div class="cta-banner">
      <div class="cta-banner-title">¿Ya viste suficiente? Asegura tu paquete</div>
      <p class="cta-banner-sub">Inventario limitado · Mercancía 100% original lista para revender.</p>
      <div class="cta-banner-price js-count-price" data-count="scroll" data-final="{{ p.precio_total_num }}">{{ p.precio_total }}</div>
      <button type="button" class="btn btn-primary js-buy-now">Comprar Ahora 🔥</button>
    </div>
  </div>
</div>
{% endif %}
{% endfor %}

<!-- ===== FICHA TÉCNICA: acordeón ===== -->
<div class="story-section accordion-section">
  <div class="container">
    <div class="story-head reveal js-section-toggle is-open" role="button" tabindex="0" aria-expanded="true" aria-controls="specs-panel">
      <div class="story-head-text">
        <div class="story-eyebrow">FICHA TÉCNICA</div>
        <h2 class="story-title">Especificaciones completas</h2>
      </div>
      <svg class="accordion-chevron" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M6 9l6 6 6-6"/></svg>
    </div>
    <div class="accordion-panel is-open" id="specs-panel">
      <div class="specs-grid">
        {% for key, label, value in p.specs %}
        <div class="spec-card reveal" style="transition-delay:{{ (loop.index0 % 6) * 60 }}ms">
          <div class="spec-icon">{{ spec_icon(key) }}</div>
          <div class="spec-text">
            <div class="spec-label">{{ label }}</div>
            <div class="spec-value">{{ value }}</div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<!-- ===== DESCRIPCIÓN: mismo formato de landing page, en acordeón ===== -->
<div class="story-section accordion-section">
  <div class="container">
    <div class="story-head reveal js-section-toggle is-open" role="button" tabindex="0" aria-expanded="true" aria-controls="desc-panel">
      <div class="story-head-text">
        <div class="story-eyebrow">SOBRE EL PAQUETE</div>
        <h2 class="story-title">Descripción</h2>
      </div>
      <svg class="accordion-chevron" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M6 9l6 6 6-6"/></svg>
    </div>
    <div class="accordion-panel is-open" id="desc-panel">
      <div class="desc-block reveal">
        <svg class="desc-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h6"/></svg>
        <p class="desc-text">{{ p.descripcion }}</p>
      </div>
    </div>
  </div>
</div>

<!-- ===== CTA FINAL: agenda tu videollamada ===== -->
<div class="final-cta videocall-cta">
  <div class="container">
    <div class="cta-banner final-cta-inner videocall-inner">
      <div class="story-eyebrow">VERIFÍCALO ANTES DE COMPRAR</div>
      <div class="cta-banner-title">Agenda tu videollamada y conoce el inventario en vivo</div>
      <p class="cta-banner-sub">Te mostramos cada pieza del paquete por video en tiempo real, antes de que decidas comprar. 100% transparencia, cero sorpresas.</p>
      <a href="#" id="videocall-whatsapp-btn" class="btn btn-primary js-videocall-btn" target="_blank" rel="noopener">Agendar videollamada 🎥</a>
    </div>
  </div>
</div>

{% if p.testimonios %}
<!-- ===== TESTIMONIOS: capturas reales de clientes ===== -->
<div class="story-section testimonials-section">
  <div class="container">
    <div class="story-head reveal">
      <div class="story-eyebrow">CLIENTES REALES</div>
      <h2 class="story-title">Esto dicen quienes ya compraron</h2>
      <p class="story-sub">Capturas reales de conversaciones con clientes que ya recibieron su paquete y están revendiendo con éxito.</p>
    </div>
    <div class="photo-carousel-wrap">
      <button type="button" class="carousel-arrow js-carousel-prev" aria-label="Ver testimonios anteriores" disabled>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div class="photo-grid photo-grid--scroll testimonials-grid js-carousel-track">
        {% for src in p.testimonios %}
        <button type="button" class="photo-tile testimonial-tile js-lightbox-img reveal" data-group="testimonios" style="transition-delay:{{ (loop.index0 % 6) * 70 }}ms">
          <img src="{{ src }}" alt="Testimonio de cliente STRAVEN" loading="lazy">
        </button>
        {% endfor %}
      </div>
      <button type="button" class="carousel-arrow js-carousel-next" aria-label="Ver más testimonios">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
    <div class="carousel-dots js-carousel-dots" role="tablist" aria-label="Navegación del carrusel de testimonios"></div>
  </div>
</div>
{% endif %}

<div class="mobile-buybar">
  <div class="mobile-buybar-row">
    <div class="mobile-buybar-price">
      <div class="p js-count-price" data-count="load" data-final="{{ p.precio_total_num }}">{{ p.precio_total }}</div>
      <div class="u">{{ p.precio_unitario }} c/u</div>
    </div>
    <button type="button" class="btn btn-primary js-buy-now">Comprar Ahora 🔥</button>
  </div>
  <a href="#" class="btn btn-whatsapp btn-block js-whatsapp-quote" target="_blank" rel="noopener">
    <svg viewBox="0 0 32 32" width="16" height="16" fill="currentColor"><path d="M16.04 2.67C8.84 2.67 3 8.5 3 15.7c0 2.84.93 5.46 2.5 7.6L4 29.33l6.2-1.63a12.9 12.9 0 0 0 5.84 1.4h.01c7.2 0 13.04-5.83 13.04-13.03 0-3.48-1.36-6.75-3.82-9.2a12.93 12.93 0 0 0-9.23-3.8Zm0 23.4h-.01a10.8 10.8 0 0 1-5.5-1.5l-.4-.24-4.1 1.08 1.1-4-.26-.42a10.78 10.78 0 0 1-1.65-5.74c0-5.98 4.87-10.84 10.85-10.84a10.8 10.8 0 0 1 7.68 3.18 10.78 10.78 0 0 1 3.18 7.67c0 5.98-4.87 10.81-10.85 10.81Zm5.95-8.1c-.33-.16-1.93-.95-2.23-1.06-.3-.11-.51-.16-.73.16-.21.32-.84 1.06-1.03 1.27-.19.22-.38.24-.7.08-.32-.16-1.34-.49-2.55-1.57-.94-.84-1.58-1.87-1.76-2.19-.19-.32-.02-.49.15-.65.16-.16.36-.41.54-.62.18-.21.24-.36.36-.6.12-.24.06-.44-.03-.6-.1-.16-.66-1.6-.91-2.18-.24-.58-.49-.5-.68-.51h-.58c-.19 0-.5.07-.76.36-.27.29-1.03 1-1.03 2.45s1.06 2.84 1.21 3.04c.16.2 2.13 3.25 5.16 4.43 3.03 1.18 3.03.79 3.58.74.54-.05 1.93-.79 2.2-1.55.28-.76.28-1.41.2-1.55-.08-.13-.3-.21-.62-.37Z"/></svg>
    Solicitar cotización por WhatsApp
  </a>
</div>

<script type="application/json" id="product-data">{{ product_json|safe }}</script>
{% endblock %}
{% block extra_scripts %}<script src="{{ asset_prefix }}js/product.js"></script>{% endblock %}
