{% extends "base.html.j2" %}
{% block meta_desc %}{{ p.meta_desc }}{% endblock %}
{% block body_class %}has-buybar{% endblock %}
{% block content %}
<div class="container product-nav">
  <a href="{{ asset_prefix }}index.html" class="back-link">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M11 18l-6-6 6-6"/></svg>
    Volver al catálogo
  </a>
</div>

<!-- ===== HERO: foto principal + caja de compra ===== -->
<div class="container product-top">
  <div class="product-grid">

    <div class="gallery">
      <button type="button" class="gallery-main js-lightbox-img" data-group="principal">
        <img src="{{ p.principal_detail }}" alt="{{ p.nombre }}">
      </button>
    </div>

    <div class="buy-box">
      <div class="buy-eyebrow">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
        100% Original · Importado de EUA
      </div>
      <h1 class="buy-title">{{ p.nombre }}</h1>

      {% if p.logos %}
      <div class="brand-logos">
        {% for logo in p.logos %}<img src="{{ logo }}" class="brand-logo-chip" alt="Marca incluida en el paquete">{% endfor %}
      </div>
      {% endif %}

      <div class="buy-price-block">
        <span class="buy-price">{{ p.precio_total }}</span>
        <span class="buy-price-label">precio del paquete completo</span>
      </div>
      <div class="buy-unit">{{ p.precio_unitario }} c/u · {{ p.pzas }} piezas · {{ p.categoria }}</div>

      <div class="qty-row">
        <span class="qty-row-label">Cantidad de paquetes</span>
        <div class="qty-stepper">
          <button class="js-qty-dec" aria-label="Restar">−</button>
          <span class="js-qty-value">1</span>
          <button class="js-qty-inc" aria-label="Sumar">+</button>
        </div>
      </div>

      <div class="buy-actions">
        <button type="button" class="btn btn-primary btn-block js-buy-now">Comprar Ahora</button>
        <button type="button" class="btn btn-secondary btn-block js-add-to-cart">Agregar al Carrito</button>
      </div>
      <div class="added-toast" id="added-toast">✓ Paquete agregado a tu pedido</div>

      {% if p.gallery_sections %}
      <div class="scroll-hint">
        <span>Desliza para ver todos los detalles del paquete</span>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 9l6 6 6-6"/></svg>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<!-- ===== MINI-SECCIÓN: facilidades de pago (antes de "Detalles") ===== -->
<div class="story-section payment-mini-section">
  <div class="container">
    <div class="story-head reveal">
      <div class="story-eyebrow">Facilidades de pago</div>
      <h2 class="story-title">Paga hasta en 3 meses sin intereses</h2>
    </div>
    <div class="payment-methods">
      <div class="payment-method reveal" style="transition-delay:0ms">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.5"/><path d="M6 9v6M18 9v6"/></svg>
        <span>Efectivo</span>
      </div>
      <div class="payment-method reveal" style="transition-delay:70ms">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h13M13 3l4 4-4 4"/><path d="M20 17H7M11 21l-4-4 4-4"/></svg>
        <span>Transferencia SPEI</span>
      </div>
      <div class="payment-method reveal" style="transition-delay:140ms">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/><path d="M14 15h4"/></svg>
        <span>Tarjetas de débito y crédito</span>
      </div>
      <div class="payment-method reveal" style="transition-delay:210ms">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l1.5-5h15L21 9"/><path d="M4 9v10a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V9"/><path d="M9 20v-6h6v6"/><path d="M3 9h18"/></svg>
        <span>Oxxo Pay</span>
      </div>
      <div class="payment-method reveal" style="transition-delay:280ms">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="13" rx="2"/><path d="M2 10h20"/><circle cx="17" cy="14.5" r="1.4"/></svg>
        <span>PayPal</span>
      </div>
    </div>
  </div>
</div>

<!-- ===== SECCIONES NARRATIVAS: aparecen al hacer scroll ===== -->
{% for sec in p.gallery_sections %}
{% if sec.key == "individuales" %}
<!-- ===== MINI-SECCIÓN: envío gratis (antes de "fotografías individuales") ===== -->
<div class="story-section shipping-mini-section">
  <div class="container">
    <div class="shipping-mini reveal">
      <div class="shipping-mini-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="6" width="14" height="11"/><path d="M15 9h4l3 3v5h-7z"/><circle cx="6" cy="19" r="1.6"/><circle cx="17" cy="19" r="1.6"/></svg>
      </div>
      <h2 class="shipping-mini-title">ENVÍO GRATIS</h2>
      <p class="shipping-mini-sub">Envíos a toda la República Mexicana</p>
    </div>
  </div>
</div>
{% endif %}
<div class="story-section">
  <div class="container">
    <div class="story-head reveal">
      <div class="story-eyebrow">{{ sec.eyebrow }}</div>
      <h2 class="story-title">{{ sec.title }}</h2>
      <p class="story-sub">{{ sec.subtitle }}</p>
    </div>

    {% if sec.key == "video" %}
    <div class="video-frame reveal">
      <video controls playsinline {% if sec.fotos[0].poster %}poster="{{ sec.fotos[0].poster }}"{% endif %}>
        <source src="{{ sec.fotos[0].src }}">
      </video>
    </div>
    {% else %}
    <div class="photo-grid{{ ' photo-grid--large' if sec.key == 'grupales' else '' }}{{ ' photo-grid--scroll' if sec.key == 'individuales' else '' }}">
      {% for it in sec.fotos %}
      <button type="button" class="photo-tile js-lightbox-img reveal" data-group="{{ sec.key }}" style="transition-delay:{{ (loop.index0 % 6) * 70 }}ms">
        <img src="{{ it.src }}" alt="{{ p.nombre }} — {{ sec.title }}" loading="lazy">
      </button>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>

{% if loop.index == 2 or loop.last %}
<div class="story-section cta-banner-section">
  <div class="container">
    <div class="cta-banner">
      {% if loop.last %}
      <div class="cta-banner-title">¿Ya viste suficiente? Asegura tu paquete</div>
      <p class="cta-banner-sub">Inventario limitado · Mercancía 100% original lista para revender.</p>
      {% else %}
      <div class="cta-banner-title">No dejes que se agote tu inventario</div>
      <p class="cta-banner-sub">Paquetes mayoristas con disponibilidad limitada.</p>
      {% endif %}
      <div class="cta-banner-price">{{ p.precio_total }}</div>
      <button type="button" class="btn btn-primary js-buy-now">Comprar Ahora</button>
    </div>
  </div>
</div>
{% endif %}
{% endfor %}

<!-- ===== ESPECIFICACIONES + DESCRIPCIÓN ===== -->
<div class="container">
  <div class="detail-lower">
    <div>
      <h2 class="block-title">Descripción</h2>
      <p class="desc-text">{{ p.descripcion }}</p>
    </div>
    <div>
      <h2 class="block-title">Especificaciones completas</h2>
      <table class="specs-table">
        {% for label, value in p.specs %}
        <tr><td>{{ label }}</td><td>{{ value }}</td></tr>
        {% endfor %}
      </table>
    </div>
  </div>
</div>

<!-- ===== CTA FINAL ===== -->
<div class="final-cta">
  <div class="container">
    <div class="cta-banner final-cta-inner">
      <div class="cta-banner-title">¿Listo para hacer crecer tu inventario?</div>
      <p class="cta-banner-sub">Paquete completo de {{ p.pzas }} piezas, 100% original · Atención directa por WhatsApp.</p>
      <div class="cta-banner-price">{{ p.precio_total }}</div>
      <div class="final-cta-actions">
        <button type="button" class="btn btn-primary js-buy-now">Comprar Ahora</button>
        <button type="button" class="btn btn-secondary js-add-to-cart">Agregar al Carrito</button>
      </div>
    </div>
  </div>
</div>

<div class="mobile-buybar">
  <div class="mobile-buybar-row">
    <div class="mobile-buybar-price">
      <div class="p">{{ p.precio_total }}</div>
      <div class="u">{{ p.precio_unitario }} c/u</div>
    </div>
    <button type="button" class="btn btn-primary js-buy-now">Comprar Ahora</button>
  </div>
  <button type="button" class="btn btn-secondary btn-block js-add-to-cart">Agregar al Carrito</button>
</div>

<script type="application/json" id="product-data">{{ product_json|safe }}</script>
{% endblock %}
{% block extra_scripts %}<script src="{{ asset_prefix }}js/product.js"></script>{% endblock %}
